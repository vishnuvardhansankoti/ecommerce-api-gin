@baseUrl = http://localhost:8080

### Create customer Alex
POST {{baseUrl}}/api/v1/customers
Content-Type: application/json

{
	"first_name": "Alex",
	"last_name": "Johnson",
	"email": "alex@example.com",
	"phone": "+1-555-555-1212",
	"address": "101 Market Street, Austin, TX"
}

