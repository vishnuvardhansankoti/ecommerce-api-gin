@baseUrl = http://localhost:8080

### Create Wireless Mouse
POST {{baseUrl}}/api/v1/products
Content-Type: application/json

{
	"name": "Wireless Mouse",
	"description": "Bluetooth ergonomic mouse",
	"sku": "MOUSE-1001",
	"price": 49.99,
	"stock": 100,
	"category_id": 1
}

